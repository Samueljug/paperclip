# Gemini-native Pi team on the Antigravity backend = your Google AI Ultra quota.
# Code Assist (gemini CLI OAuth) is the FREE tier and throttles under load; Antigravity draws
# on AI Ultra (the 100% weekly/5h pool). As of 2026-06-13 both Pi and Gemini CLI
# smoke tests accept Gemini 3.5 Flash directly; do not fall back to gpt/codex.
# Provider+login+transport live in Stage/pi-gemini-extension (google-antigravity); no-mistakes
# and gemini_run route via ~/.no-mistakes/bin/gemini-antigravity-wrapper.
OPENCLAW_PI_MODEL_CONTROLLER=google-antigravity/gemini-3.5-flash:high
OPENCLAW_PI_MODEL_ORCH=google-antigravity/gemini-3.5-flash:high
OPENCLAW_PI_MODEL_LEAD=google-antigravity/gemini-3.5-flash:high
OPENCLAW_PI_MODEL_PLANNING=google-antigravity/gemini-3.5-flash:high
OPENCLAW_PI_MODEL_WORKER=google-antigravity/gemini-3.5-flash:high
OPENCLAW_PI_MODEL_RESEARCH=google-antigravity/gemini-3.5-flash:high
OPENCLAW_PI_MODEL_ARCHITECT=google-antigravity/gemini-3.5-flash:high
OPENCLAW_PI_MODEL_SECURITY=google-antigravity/gemini-3.5-flash:high
OPENCLAW_PI_MODEL_SELF_IMPROVEMENT=google-antigravity/gemini-3.5-flash:high
OPENCLAW_PI_MODEL_SELF_IMPROVEMENT_WORKER=google-antigravity/gemini-3.5-flash:high
OPENCLAW_PI_MODEL_MEMORY_WORKER=google-antigravity/gemini-3.5-flash:high
OPENCLAW_PI_MODEL_PROBLEM=google-antigravity/gemini-3.5-flash:high
OPENCLAW_GEMINI_BRIDGE_ENABLED=1
# gemini_run shells this wrapper -> pi/Antigravity (AI Ultra), falls back to real gemini CLI
OPENCLAW_GEMINI_BIN=/Users/samuelimini/.no-mistakes/bin/gemini-antigravity-wrapper
OPENCLAW_GEMINI_BRIDGE_MODEL=gemini-3.5-flash
OPENCLAW_CLAUDE_BRIDGE_ENABLED=0
OPENCLAW_CLAUDE_BRIDGE_MODEL=disabled
OPENCLAW_CLAUDE_BRIDGE_EFFORT=off
