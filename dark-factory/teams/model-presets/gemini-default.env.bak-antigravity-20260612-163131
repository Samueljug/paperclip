# Gemini-native Pi team, pinned to Gemini 3.5 Flash.
# IMPORTANT (2026-06-12): on the Code Assist (gemini CLI OAuth) subscription backend the
# ONLY id that serves Gemini 3.5 Flash is `gemini-3-flash-preview`. The stable ids
# (gemini-3.5-flash / gemini-3-flash / gemini-flash-latest) all return 404 "Requested
# entity was not found" there (verified). So the `gemini-3.5-flash` pins below are kept
# and ALIASED to gemini-3-flash-preview at the boundary:
#   - pi model path:  Stage/pi-gemini-extension/index.ts  (ALIASES map)
#   - gemini_run tool: extensions/gemini-cli-bridge.ts    (GEMINI_MODEL_ALIASES map)
# This is NOT a preview "fallback" — it is the SAME 3.5 Flash model, just the id Google
# exposes on Code Assist. Do NOT remove those aliases or it 404s again.
OPENCLAW_PI_MODEL_CONTROLLER=google-gemini-cli/gemini-3.5-flash:high
OPENCLAW_PI_MODEL_ORCH=google-gemini-cli/gemini-3.5-flash:high
OPENCLAW_PI_MODEL_LEAD=google-gemini-cli/gemini-3.5-flash:high
OPENCLAW_PI_MODEL_PLANNING=google-gemini-cli/gemini-3.5-flash:high
OPENCLAW_PI_MODEL_WORKER=google-gemini-cli/gemini-3.5-flash:high
OPENCLAW_PI_MODEL_RESEARCH=google-gemini-cli/gemini-3.5-flash:high
OPENCLAW_PI_MODEL_ARCHITECT=google-gemini-cli/gemini-3.5-flash:high
OPENCLAW_PI_MODEL_SECURITY=google-gemini-cli/gemini-3.5-flash:high
OPENCLAW_PI_MODEL_SELF_IMPROVEMENT=google-gemini-cli/gemini-3.5-flash:high
OPENCLAW_PI_MODEL_SELF_IMPROVEMENT_WORKER=google-gemini-cli/gemini-3.5-flash:high
OPENCLAW_PI_MODEL_MEMORY_WORKER=google-gemini-cli/gemini-3.5-flash:high
OPENCLAW_PI_MODEL_PROBLEM=google-gemini-cli/gemini-3.5-flash:high
OPENCLAW_GEMINI_BRIDGE_ENABLED=1
OPENCLAW_GEMINI_BRIDGE_MODEL=gemini-3.5-flash
OPENCLAW_CLAUDE_BRIDGE_ENABLED=0
OPENCLAW_CLAUDE_BRIDGE_MODEL=claude-opus-4-8
OPENCLAW_CLAUDE_BRIDGE_EFFORT=max
