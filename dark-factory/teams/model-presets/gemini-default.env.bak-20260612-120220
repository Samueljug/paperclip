# Gemini-CLI-led Pi team. Pi shells use Claude Sonnet as a lightweight coordinator loop;
# all substantive work is delegated to the Gemini CLI via gemini_run (gemini-cli-bridge.ts).
# google is not a Pi auth provider — the CLI bridge is the correct path for Gemini work.
OPENCLAW_PI_MODEL_CONTROLLER=anthropic/claude-sonnet-4-5:high
OPENCLAW_PI_MODEL_ORCH=anthropic/claude-sonnet-4-5:high
OPENCLAW_PI_MODEL_LEAD=anthropic/claude-sonnet-4-5:high
OPENCLAW_PI_MODEL_PLANNING=anthropic/claude-sonnet-4-5:high
OPENCLAW_PI_MODEL_WORKER=anthropic/claude-sonnet-4-5:high
OPENCLAW_PI_MODEL_RESEARCH=anthropic/claude-sonnet-4-5:high
OPENCLAW_PI_MODEL_ARCHITECT=anthropic/claude-sonnet-4-5:high
OPENCLAW_PI_MODEL_SECURITY=anthropic/claude-sonnet-4-5:high
OPENCLAW_PI_MODEL_SELF_IMPROVEMENT=anthropic/claude-sonnet-4-5:high
OPENCLAW_PI_MODEL_SELF_IMPROVEMENT_WORKER=anthropic/claude-sonnet-4-5:high
OPENCLAW_PI_MODEL_MEMORY_WORKER=anthropic/claude-sonnet-4-5:high
OPENCLAW_PI_MODEL_PROBLEM=anthropic/claude-sonnet-4-5:high
OPENCLAW_GEMINI_BRIDGE_ENABLED=1
# Empty means use the authenticated Gemini CLI default model. Do not hardcode a
# Gemini model name here unless a smoke test proves the installed CLI/account
# can access it.
OPENCLAW_GEMINI_BRIDGE_MODEL=
OPENCLAW_CLAUDE_BRIDGE_ENABLED=1
OPENCLAW_CLAUDE_BRIDGE_MODEL=claude-opus-4-8
OPENCLAW_CLAUDE_BRIDGE_EFFORT=max
