{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/dark-factory/acceptance-contract.schema.json",
  "title": "Dark Factory AcceptanceContract",
  "type": "object",
  "additionalProperties": false,
  "required": ["frozen", "intentConfirmation", "criteria"],
  "properties": {
    "frozen": { "type": "boolean" },
    "intentConfirmation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "status"],
      "properties": {
        "required": { "type": "boolean" },
        "status": { "type": "string", "enum": ["not_required", "pending", "confirmed"] },
        "confirmedBy": { "type": "string" },
        "confirmedAt": { "type": "string" }
      }
    },
    "criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "statement", "verification"],
        "properties": {
          "id": { "type": "string" },
          "statement": { "type": "string" },
          "verification": { "type": "string" },
          "holdout": { "type": "boolean" }
        }
      }
    }
  }
}
