{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/dark-factory/test-contract.schema.json",
  "title": "Dark Factory TestContract",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "frozen", "authorRole", "suites"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "required": { "type": "boolean" },
    "frozen": { "const": true },
    "authorRole": { "type": "string", "minLength": 1 },
    "createdAt": { "type": "string" },
    "acceptanceCriteria": {
      "type": "array",
      "items": { "type": "string" }
    },
    "preFixReproduction": {
      "type": "object",
      "additionalProperties": true
    },
    "suites": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "visible": {
          "type": "array",
          "items": { "$ref": "#/$defs/testCommand" }
        },
        "holdout": {
          "type": "array",
          "items": { "$ref": "#/$defs/testCommand" }
        }
      },
      "anyOf": [
        { "required": ["visible"] },
        { "required": ["holdout"] }
      ]
    },
    "fixtures": {
      "type": "array",
      "items": { "type": "string" }
    },
    "environment": {
      "type": "object",
      "additionalProperties": true
    },
    "expectedEvidence": {
      "type": "array",
      "items": { "type": "string" }
    },
    "protectedPaths": {
      "type": "array",
      "items": { "type": "string" }
    },
    "amendments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    }
  },
  "$defs": {
    "testCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "command"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "summary": { "type": "string" },
        "level": {
          "type": "string",
          "enum": ["unit", "integration", "api", "browser", "visual", "security", "static", "custom"]
        },
        "command": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "cwd": { "type": "string" },
        "mapsTo": {
          "type": "array",
          "items": { "type": "string" }
        },
        "redBeforeGreen": { "type": "boolean" },
        "sealed": { "type": "boolean" }
      }
    }
  }
}
